{
  "name": "Resource",
  "type": "object",
  "properties": {
    "mitzvah_id": {
      "type": "string",
      "description": "Associated mitzvah ID"
    },
    "title_ru": {
      "type": "string"
    },
    "content_ru": {
      "type": "string",
      "description": "Main Russian content (markdown)"
    },
    "hebrew_text": {
      "type": "string",
      "description": "Hebrew text blocks"
    },
    "transliteration": {
      "type": "string",
      "description": "Russian transliteration"
    },
    "translation_ru": {
      "type": "string",
      "description": "Russian translation"
    },
    "instructions_ru": {
      "type": "string",
      "description": "Step-by-step instructions"
    },
    "image_url": {
      "type": "string"
    },
    "external_link": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "needs_review": {
      "type": "boolean",
      "default": true,
      "description": "Marked for review before launch"
    },
    "is_published": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "title_ru",
    "content_ru"
  ]
}